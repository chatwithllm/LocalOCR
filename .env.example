# =============================================================================
# Grocery Inventory & Savings Management System
# Environment Variables — Copy this file to .env and fill in real values
# =============================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Google Gemini Vision API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI Vision API (secondary OCR fallback) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_OCR_MODEL=gpt-4.1-mini

# --- MQTT Broker ---
MQTT_BROKER=mqtt
MQTT_PORT=1883

# --- Flask Backend ---
FLASK_ENV=development
FLASK_PORT=8080
FLASK_DEBUG=1

# --- Database ---
DATABASE_URL=sqlite:////data/db/grocery.db

# --- Ollama (fallback OCR) ---
OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=llava:7b

# --- Daily Recommendations ---
RECOMMENDATION_TIME=08:00

# --- Receipt Image Retention ---
RECEIPT_RETENTION_MONTHS=12

# --- Authentication ---
# Generate a token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Tokens are stored hashed in the DB; set initial admin token for first-run setup
INITIAL_ADMIN_TOKEN=your_initial_admin_token_here
